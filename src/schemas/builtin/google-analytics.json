{
  "google-analytics-api": {
    "$comment": "Any request to the Google Analytics API (data and admin endpoints).",
    "properties": {
      "domain": {
        "enum": [
          "analyticsdata.googleapis.com",
          "analyticsadmin.googleapis.com"
        ]
      }
    },
    "required": [
      "domain"
    ]
  },
  "google-analytics-read-all": {
    "$comment": "Read-only access to all Google Analytics resources.",
    "properties": {
      "method": {
        "const": "GET"
      }
    },
    "required": [
      "method"
    ]
  },
  "google-analytics-write-all": {
    "$comment": "Write access to all Google Analytics resources.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      }
    },
    "required": [
      "method"
    ]
  },
  "google-analytics-run-reports": {
    "$comment": "Run analytics reports, including standard, pivot, real-time, batch, compatibility, and access reports.",
    "properties": {
      "method": {
        "const": "POST"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+[a-z]*/(properties|accounts)/[^/]+:(runReport|batchRunReports|runPivotReport|batchRunPivotReports|runRealtimeReport|checkCompatibility|runAccessReport)$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-analytics-read-metadata": {
    "$comment": "Read metadata (available dimensions and metrics) for an analytics property.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+[a-z]*/properties/[^/]+/metadata$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-analytics-read-accounts": {
    "$comment": "List or view Google Analytics accounts and account summaries.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+[a-z]*/(accounts|accountSummaries)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-analytics-read-properties": {
    "$comment": "List or view Google Analytics properties.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+[a-z]*/properties(/[^/]+)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-analytics-write-properties": {
    "$comment": "Create, update, or delete Google Analytics properties.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+[a-z]*/properties(/[^/]+)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-analytics-read-data-streams": {
    "$comment": "List or view data streams for a Google Analytics property.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+[a-z]*/properties/[^/]+/dataStreams(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-analytics-write-data-streams": {
    "$comment": "Create, update, or delete data streams for a Google Analytics property.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+[a-z]*/properties/[^/]+/dataStreams(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  }
}
