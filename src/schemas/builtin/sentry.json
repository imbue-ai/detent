{
  "sentry-api": {
    "properties": {
      "domain": {
        "const": "sentry.io"
      }
    },
    "required": [
      "domain"
    ]
  },
  "sentry-read-all": {
    "properties": {
      "method": {
        "const": "GET"
      }
    },
    "required": [
      "method"
    ]
  },
  "sentry-write-all": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      }
    },
    "required": [
      "method"
    ]
  },
  "sentry-read-issues": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/api/0/(issues|organizations/[^/]+/issues|projects/[^/]+/[^/]+/(issues|events))(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "sentry-write-issues": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/api/0/(issues|organizations/[^/]+/issues|projects/[^/]+/[^/]+/issues)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "sentry-read-projects": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/api/0/projects(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "sentry-write-projects": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/api/0/(projects|teams/[^/]+/[^/]+/projects)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "sentry-read-organizations": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/api/0/organizations(/[^/]+)?/?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "sentry-read-teams": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/api/0/(teams|organizations/[^/]+/teams)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "sentry-read-releases": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/api/0/(organizations/[^/]+/releases|projects/[^/]+/[^/]+/releases)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "sentry-write-releases": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/api/0/(organizations/[^/]+/releases|projects/[^/]+/[^/]+/releases)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  }
}
