{
  "google-drive-api": {
    "$comment": "Any request to the Google Drive API.",
    "properties": {
      "domain": {
        "const": "www.googleapis.com"
      },
      "path": {
        "type": "string",
        "pattern": "^/(upload/)?drive/"
      }
    },
    "required": [
      "domain",
      "path"
    ]
  },
  "google-drive-read-all": {
    "$comment": "Read anything from Google Drive.",
    "properties": {
      "method": {
        "const": "GET"
      }
    },
    "required": [
      "method"
    ]
  },
  "google-drive-write-all": {
    "$comment": "Create, update, or delete anything in Google Drive.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      }
    },
    "required": [
      "method"
    ]
  },
  "google-drive-read-files": {
    "$comment": "List files or retrieve file metadata.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/drive/v[0-9]+/files(/[^/]+)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-drive-write-files": {
    "$comment": "Create, upload, update, or delete files.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/(upload/)?drive/v[0-9]+/files(/[^/]+)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-drive-read-permissions": {
    "$comment": "View sharing permissions on files.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/drive/v[0-9]+/files/[^/]+/permissions(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-drive-write-permissions": {
    "$comment": "Share, modify, or revoke sharing permissions on files.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/drive/v[0-9]+/files/[^/]+/permissions(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-drive-read-comments": {
    "$comment": "View comments and replies on files.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/drive/v[0-9]+/files/[^/]+/comments(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-drive-write-comments": {
    "$comment": "Add, edit, or delete comments and replies on files.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/drive/v[0-9]+/files/[^/]+/comments(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-drive-read-about": {
    "$comment": "Retrieve information about the user's Drive account and settings.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/drive/v[0-9]+/about$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  }
}
