{
  "google-docs-api": {
    "$comment": "Any request to the Google Docs API.",
    "properties": {
      "domain": {
        "const": "docs.googleapis.com"
      }
    },
    "required": [
      "domain"
    ]
  },
  "google-docs-read-all": {
    "$comment": "Read any Google Docs resource.",
    "properties": {
      "method": {
        "const": "GET"
      }
    },
    "required": [
      "method"
    ]
  },
  "google-docs-write-all": {
    "$comment": "Create, update, or delete any Google Docs resource.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      }
    },
    "required": [
      "method"
    ]
  },
  "google-docs-read-documents": {
    "$comment": "Read a specific document.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/documents/[^/]+$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-docs-write-documents": {
    "$comment": "Create, update, or delete documents.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/documents(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-docs-create-documents": {
    "$comment": "Create new documents.",
    "properties": {
      "method": {
        "const": "POST"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/documents$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-docs-update-documents": {
    "$comment": "Apply batch updates to a document's content.",
    "properties": {
      "method": {
        "const": "POST"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/documents/[^/]+:batchUpdate$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  }
}
