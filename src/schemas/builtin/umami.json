{
  "umami-api": {
    "$comment": "Identifies requests to the Umami Cloud API.",
    "properties": {
      "domain": {
        "const": "api.umami.is"
      }
    },
    "required": [
      "domain"
    ]
  },
  "umami-read-all": {
    "$comment": "Read any Umami resource.",
    "properties": {
      "method": {
        "const": "GET"
      }
    },
    "required": [
      "method"
    ]
  },
  "umami-write-all": {
    "$comment": "Create, update, or delete any Umami resource.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      }
    },
    "required": [
      "method"
    ]
  },
  "umami-read-websites": {
    "$comment": "List websites or view a single website's details.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^(/v[0-9]+|/api)/websites(/[^/]+)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "umami-write-websites": {
    "$comment": "Create, update, or delete websites.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^(/v[0-9]+|/api)/websites(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "umami-read-stats": {
    "$comment": "View analytics data for a website, including pageviews, sessions, events, and metrics.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^(/v[0-9]+|/api)/websites/[^/]+/(active|daterange|events|event-data|metrics|pageviews|stats|sessions|session-data)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "umami-read-reports": {
    "$comment": "List or view reports.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^(/v[0-9]+|/api)/reports(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "umami-write-reports": {
    "$comment": "Create, update, or delete reports.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^(/v[0-9]+|/api)/reports(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "umami-read-teams": {
    "$comment": "List or view teams and their details.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^(/v[0-9]+|/api)/teams(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "umami-write-teams": {
    "$comment": "Create, update, or delete teams.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^(/v[0-9]+|/api)/teams(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "umami-read-me": {
    "$comment": "View the current user's profile information.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^(/v[0-9]+|/api)/me(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  }
}
