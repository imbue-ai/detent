{
  "umami-api": {
    "properties": {
      "domain": {
        "const": "api.umami.is"
      }
    },
    "required": [
      "domain"
    ]
  },
  "umami-read-all": {
    "properties": {
      "method": {
        "const": "GET"
      }
    },
    "required": [
      "method"
    ]
  },
  "umami-write-all": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      }
    },
    "required": [
      "method"
    ]
  },
  "umami-read-websites": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^(/v[0-9]+|/api)/websites(/[^/]+)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "umami-write-websites": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^(/v[0-9]+|/api)/websites(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "umami-read-stats": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^(/v[0-9]+|/api)/websites/[^/]+/(active|daterange|events|event-data|metrics|pageviews|stats|sessions|session-data)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "umami-read-reports": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^(/v[0-9]+|/api)/reports(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "umami-write-reports": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^(/v[0-9]+|/api)/reports(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "umami-read-teams": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^(/v[0-9]+|/api)/teams(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "umami-write-teams": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^(/v[0-9]+|/api)/teams(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "umami-read-me": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^(/v[0-9]+|/api)/me(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  }
}
