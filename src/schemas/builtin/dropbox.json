{
  "dropbox-api": {
    "properties": {
      "domain": {
        "enum": [
          "api.dropboxapi.com",
          "content.dropboxapi.com",
          "notify.dropboxapi.com"
        ]
      }
    },
    "required": [
      "domain"
    ]
  },
  "dropbox-files": {
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/2/files/"
      }
    },
    "required": [
      "path"
    ]
  },
  "dropbox-files-read": {
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/2/files/(list_|get_|download|export|search|copy_reference/get|tags/get)"
      }
    },
    "required": [
      "path"
    ]
  },
  "dropbox-files-write": {
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/2/files/(copy(?!_reference/get)|create_folder|delete|lock_file|move|paper/|permanently_delete|restore|save_url|tags/(add|remove)|unlock_file|upload)"
      }
    },
    "required": [
      "path"
    ]
  },
  "dropbox-sharing": {
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/2/sharing/"
      }
    },
    "required": [
      "path"
    ]
  },
  "dropbox-sharing-read": {
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/2/sharing/(check_|get_|list_)"
      }
    },
    "required": [
      "path"
    ]
  },
  "dropbox-sharing-write": {
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/2/sharing/(add_|create_|modify_|mount_|relinquish_|remove_|revoke_|set_|share_|transfer_|unmount_|unshare_|update_)"
      }
    },
    "required": [
      "path"
    ]
  },
  "dropbox-account": {
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/2/users/"
      }
    },
    "required": [
      "path"
    ]
  },
  "dropbox-file-requests": {
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/2/file_requests/"
      }
    },
    "required": [
      "path"
    ]
  },
  "dropbox-contacts": {
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/2/contacts/"
      }
    },
    "required": [
      "path"
    ]
  }
}
