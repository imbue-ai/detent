{
  "dropbox-api": {
    "$comment": "Any Dropbox API activity.",
    "properties": {
      "domain": {
        "enum": [
          "api.dropboxapi.com",
          "content.dropboxapi.com",
          "notify.dropboxapi.com"
        ]
      }
    },
    "required": [
      "domain"
    ]
  },
  "dropbox-files": {
    "$comment": "Any Dropbox file operations.",
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/2/files/"
      }
    },
    "required": [
      "path"
    ]
  },
  "dropbox-files-read": {
    "$comment": "Read-only Dropbox file operations such as listing, downloading, searching, and exporting files.",
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/2/files/(list_|get_|download|export|search|copy_reference/get|tags/get)"
      }
    },
    "required": [
      "path"
    ]
  },
  "dropbox-files-write": {
    "$comment": "Dropbox file modifications such as copying, moving, uploading, deleting, and organizing files and folders.",
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/2/files/(copy(?!_reference/get)|create_folder|delete|lock_file|move|paper/|permanently_delete|restore|save_url|tags/(add|remove)|unlock_file|upload)"
      }
    },
    "required": [
      "path"
    ]
  },
  "dropbox-sharing": {
    "$comment": "Any Dropbox sharing operations.",
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/2/sharing/"
      }
    },
    "required": [
      "path"
    ]
  },
  "dropbox-sharing-read": {
    "$comment": "Read-only Dropbox sharing operations such as checking permissions and listing shared items.",
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/2/sharing/(check_|get_|list_)"
      }
    },
    "required": [
      "path"
    ]
  },
  "dropbox-sharing-write": {
    "$comment": "Dropbox sharing modifications such as creating, updating, and revoking shared links and folder memberships.",
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/2/sharing/(add_|create_|modify_|mount_|relinquish_|remove_|revoke_|set_|share_|transfer_|unmount_|unshare_|update_)"
      }
    },
    "required": [
      "path"
    ]
  },
  "dropbox-account": {
    "$comment": "Dropbox user account information.",
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/2/users/"
      }
    },
    "required": [
      "path"
    ]
  },
  "dropbox-file-requests": {
    "$comment": "Dropbox file request operations.",
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/2/file_requests/"
      }
    },
    "required": [
      "path"
    ]
  },
  "dropbox-contacts": {
    "$comment": "Dropbox contacts operations.",
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/2/contacts/"
      }
    },
    "required": [
      "path"
    ]
  }
}
