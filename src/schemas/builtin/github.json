{
  "github-rest-api": {
    "properties": {
      "domain": {
        "const": "api.github.com"
      },
      "path": {
        "type": "string",
        "not": {
          "pattern": "^/graphql$"
        }
      }
    },
    "required": [
      "domain",
      "path"
    ]
  },
  "github-git": {
    "properties": {
      "domain": {
        "const": "github.com"
      },
      "path": {
        "type": "string",
        "pattern": "^/[^/]+/[^/]+/(info/refs|git-upload-pack|git-receive-pack)$"
      }
    },
    "required": [
      "domain",
      "path"
    ]
  },
  "github-git-read": {
    "anyOf": [
      {
        "properties": {
          "method": {
            "const": "GET"
          },
          "path": {
            "type": "string",
            "pattern": "^/[^/]+/[^/]+/info/refs$"
          },
          "queryParams": {
            "properties": {
              "service": {
                "const": "git-upload-pack"
              }
            },
            "required": [
              "service"
            ]
          }
        },
        "required": [
          "method",
          "path",
          "queryParams"
        ]
      },
      {
        "properties": {
          "method": {
            "const": "POST"
          },
          "path": {
            "type": "string",
            "pattern": "^/[^/]+/[^/]+/git-upload-pack$"
          }
        },
        "required": [
          "method",
          "path"
        ]
      }
    ]
  },
  "github-git-write": {
    "anyOf": [
      {
        "properties": {
          "method": {
            "const": "GET"
          },
          "path": {
            "type": "string",
            "pattern": "^/[^/]+/[^/]+/info/refs$"
          },
          "queryParams": {
            "properties": {
              "service": {
                "const": "git-receive-pack"
              }
            },
            "required": [
              "service"
            ]
          }
        },
        "required": [
          "method",
          "path",
          "queryParams"
        ]
      },
      {
        "properties": {
          "method": {
            "const": "POST"
          },
          "path": {
            "type": "string",
            "pattern": "^/[^/]+/[^/]+/git-receive-pack$"
          }
        },
        "required": [
          "method",
          "path"
        ]
      }
    ]
  },
  "github-read-all": {
    "properties": {
      "method": {
        "const": "GET"
      }
    },
    "required": [
      "method"
    ]
  },
  "github-write-all": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      }
    },
    "required": [
      "method"
    ]
  },
  "github-read-repos": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/repos(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "github-write-repos": {
