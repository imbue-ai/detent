{
  "github-rest-api": {
    "$comment": "Any interaction with the GitHub REST API.",
    "properties": {
      "domain": {
        "const": "api.github.com"
      },
      "path": {
        "type": "string",
        "not": {
          "pattern": "^/graphql$"
        }
      }
    },
    "required": [
      "domain",
      "path"
    ]
  },
  "github-graphql-api": {
    "$comment": "Any interaction with the GitHub GraphQL API.",
    "properties": {
      "domain": {
        "const": "api.github.com"
      },
      "path": {
        "const": "/graphql"
      }
    },
    "required": [
      "domain",
      "path"
    ]
  },
  "github-git": {
    "$comment": "Any Git protocol operation (clone, fetch, push) on GitHub.",
    "properties": {
      "domain": {
        "const": "github.com"
      },
      "path": {
        "type": "string",
        "pattern": "^/[^/]+/[^/]+/(info/refs|git-upload-pack|git-receive-pack)$"
      }
    },
    "required": [
      "domain",
      "path"
    ]
  },
  "github-git-read": {
    "$comment": "Read-only Git operations on GitHub: clone and fetch.",
    "anyOf": [
      {
        "properties": {
          "method": {
            "const": "GET"
          },
          "path": {
            "type": "string",
            "pattern": "^/[^/]+/[^/]+/info/refs$"
          },
          "queryParams": {
            "properties": {
              "service": {
                "const": "git-upload-pack"
              }
            },
            "required": [
              "service"
            ]
          }
        },
        "required": [
          "method",
          "path",
          "queryParams"
        ]
      },
      {
        "properties": {
          "method": {
            "const": "POST"
          },
          "path": {
            "type": "string",
            "pattern": "^/[^/]+/[^/]+/git-upload-pack$"
          }
        },
        "required": [
          "method",
          "path"
        ]
      }
    ]
  },
  "github-git-write": {
    "$comment": "Git push operations on GitHub.",
    "anyOf": [
      {
        "properties": {
          "method": {
            "const": "GET"
          },
          "path": {
            "type": "string",
            "pattern": "^/[^/]+/[^/]+/info/refs$"
          },
          "queryParams": {
            "properties": {
              "service": {
                "const": "git-receive-pack"
              }
            },
            "required": [
              "service"
            ]
          }
        },
        "required": [
          "method",
          "path",
          "queryParams"
        ]
      },
      {
        "properties": {
          "method": {
            "const": "POST"
          },
          "path": {
            "type": "string",
            "pattern": "^/[^/]+/[^/]+/git-receive-pack$"
          }
        },
        "required": [
          "method",
          "path"
        ]
      }
    ]
  },
  "github-read-all": {
    "$comment": "Read any GitHub resource.",
    "properties": {
      "method": {
        "const": "GET"
      }
    },
    "required": [
      "method"
    ]
  },
  "github-write-all": {
    "$comment": "Create, update, or delete any GitHub resource.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      }
    },
    "required": [
      "method"
    ]
  },
  "github-read-repos": {
    "$comment": "Read repository information and contents.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/repos(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "github-write-repos": {
    "$comment": "Create, update, or delete repository resources.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/repos(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "github-read-issues": {
    "$comment": "Read issues and issue details.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/(repos/[^/]+/[^/]+/issues|issues)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "github-write-issues": {
    "$comment": "Create, edit, or close issues.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/repos/[^/]+/[^/]+/issues(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "github-read-pulls": {
    "$comment": "Read pull requests and their details.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/repos/[^/]+/[^/]+/pulls(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "github-write-pulls": {
    "$comment": "Create, edit, or merge pull requests.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/repos/[^/]+/[^/]+/pulls(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "github-read-gists": {
    "$comment": "Read gists.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/gists(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "github-write-gists": {
    "$comment": "Create, edit, or delete gists.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/gists(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "github-read-user": {
    "$comment": "Read the authenticated user's profile and related information.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/user(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "github-search": {
    "$comment": "Search across GitHub repositories, code, issues, and users.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/search(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "github-read-notifications": {
    "$comment": "Read notifications.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/notifications(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "github-write-notifications": {
    "$comment": "Mark notifications as read or manage notification subscriptions.",
    "properties": {
      "method": {
        "enum": [
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/notifications(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "github-read-activity": {
    "$comment": "Read GitHub activity: starring and watching (stargazers, watchers, and the repositories a user starred or watches), event streams, and feeds.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/(events|feeds|repos/[^/]+/[^/]+/(stargazers|subscribers|subscription|events)|networks/[^/]+/[^/]+/events|orgs/[^/]+/events|user/(starred|subscriptions)|users/[^/]+/(starred|subscriptions|events|received_events))(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "github-write-activity": {
    "$comment": "Star or unstar a repository, or set or delete a repository watch subscription, for the authenticated user.",
    "properties": {
      "method": {
        "enum": [
          "PUT",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/(user/starred/[^/]+/[^/]+|repos/[^/]+/[^/]+/subscription)$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  }
}
