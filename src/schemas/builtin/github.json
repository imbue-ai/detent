        "type": "string",
        "pattern": "^/repos(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "github-read-issues": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/(repos/[^/]+/[^/]+/issues|issues)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "github-write-issues": {
    "properties": {
      "method": {
        "enum": [
          "POST",
