          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/repos/[^/]+/[^/]+/issues(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
