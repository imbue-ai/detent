{
  "github-rest-api": {
    "properties": {
      "domain": {
        "const": "api.github.com"
      },
      "path": {
        "type": "string",
        "not": {
          "pattern": "^/graphql$"
        }
      }
    },
    "required": [
      "domain",
      "path"
    ]
  },
  "github-read-all": {
    "properties": {
      "method": {
        "const": "GET"
      }
    },
    "required": [
      "method"
    ]
  },
  "github-write-all": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      }
    },
    "required": [
      "method"
    ]
  },
  "github-read-repos": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/repos(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "github-write-repos": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
