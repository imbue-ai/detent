{
  "greenhouse-api": {
    "$comment": "Any request to the Greenhouse Harvest API.",
    "properties": {
      "domain": {
        "const": "harvest.greenhouse.io"
      }
    },
    "required": [
      "domain"
    ]
  },
  "greenhouse-read-all": {
    "$comment": "Read anything from Greenhouse.",
    "properties": {
      "method": {
        "const": "GET"
      }
    },
    "required": [
      "method"
    ]
  },
  "greenhouse-write-all": {
    "$comment": "Create, update, or delete anything in Greenhouse.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      }
    },
    "required": [
      "method"
    ]
  },
  "greenhouse-read-candidates": {
    "$comment": "Read candidates and prospects, including their activity feed.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/candidates(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "greenhouse-write-candidates": {
    "$comment": "Add, edit, anonymize, merge, or delete candidates and prospects.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/candidates(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "greenhouse-read-applications": {
    "$comment": "Read job applications and their offers.",
    "properties": {
      "method": {
        "const": "GET"
