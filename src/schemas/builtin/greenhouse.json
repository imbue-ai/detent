{
  "greenhouse-api": {
    "$comment": "Any request to the Greenhouse Harvest API.",
    "properties": {
      "domain": {
        "const": "harvest.greenhouse.io"
      }
    },
    "required": [
      "domain"
    ]
  },
  "greenhouse-read-all": {
    "$comment": "Read anything from Greenhouse.",
    "properties": {
      "method": {
        "const": "GET"
      }
    },
    "required": [
      "method"
    ]
  },
  "greenhouse-write-all": {
    "$comment": "Create, update, or delete anything in Greenhouse.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      }
    },
    "required": [
      "method"
    ]
  },
  "greenhouse-read-candidates": {
    "$comment": "Read candidates and prospects, including their notes, attachments, tags, education, and employment history.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v1/candidates(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "greenhouse-write-candidates": {
    "$comment": "Create, update, anonymize, merge, or delete candidates and prospects, including their notes, emails, attachments, and tags.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/v1/candidates(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
