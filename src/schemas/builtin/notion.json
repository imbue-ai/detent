{
  "notion-api": {
    "$comment": "Any request to the Notion API.",
    "properties": {
      "domain": {
        "const": "api.notion.com"
      }
    },
    "required": [
      "domain"
    ]
  },
  "notion-read-all": {
    "$comment": "Read any Notion content, including searching across all resources.",
    "anyOf": [
      {
        "properties": {
          "method": {
            "const": "GET"
          }
        },
        "required": [
          "method"
        ]
      },
      {
        "properties": {
          "method": {
            "const": "POST"
          },
          "path": {
            "type": "string",
            "pattern": "^/v1/search$"
          }
        },
        "required": [
          "method",
          "path"
        ]
      }
    ]
  },
  "notion-write-all": {
    "$comment": "Create, update, or delete any Notion content.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      }
    },
    "required": [
      "method"
    ]
  },
  "notion-read-pages": {
    "$comment": "Read Notion pages and their properties.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v1/pages(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "notion-write-pages": {
    "$comment": "Create or update Notion pages.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PATCH"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/v1/pages(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "notion-read-blocks": {
    "$comment": "Read Notion blocks (the content elements within pages).",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v1/blocks(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "notion-write-blocks": {
    "$comment": "Update or delete Notion blocks.",
    "properties": {
      "method": {
        "enum": [
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/v1/blocks(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "notion-read-databases": {
    "$comment": "Read Notion databases and their schemas.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v1/databases(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "notion-write-databases": {
    "$comment": "Create or update Notion databases.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PATCH"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/v1/databases(/[^/]+)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "notion-query-databases": {
    "$comment": "Query a Notion database to retrieve filtered and sorted entries.",
    "properties": {
      "method": {
        "const": "POST"
      },
      "path": {
        "type": "string",
        "pattern": "^/v1/databases/[^/]+/query$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "notion-read-users": {
    "$comment": "List or retrieve Notion workspace users.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v1/users(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "notion-read-comments": {
    "$comment": "Read comments on Notion pages or blocks.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v1/comments(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "notion-write-comments": {
    "$comment": "Add comments to Notion pages or blocks.",
    "properties": {
      "method": {
        "const": "POST"
      },
      "path": {
        "type": "string",
        "pattern": "^/v1/comments$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "notion-search": {
    "$comment": "Search across all Notion pages and databases.",
    "properties": {
      "method": {
        "const": "POST"
      },
      "path": {
        "type": "string",
        "pattern": "^/v1/search$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  }
}
