{
  "discord-api": {
    "$comment": "Any request to the Discord API.",
    "properties": {
      "domain": {
        "const": "discord.com"
      }
    },
    "required": [
      "domain"
    ]
  },
  "discord-read-all": {
    "$comment": "Read any Discord resource.",
    "properties": {
      "method": {
        "const": "GET"
      }
    },
    "required": [
      "method"
    ]
  },
  "discord-write-all": {
    "$comment": "Create, update, or delete any Discord resource.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      }
    },
    "required": [
      "method"
    ]
  },
  "discord-read-messages": {
    "$comment": "Read messages in Discord channels.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/api/v[0-9]+/channels/[^/]+/messages(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "discord-write-messages": {
    "$comment": "Send, edit, or delete messages in Discord channels.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/api/v[0-9]+/channels/[^/]+/messages(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "discord-read-channels": {
    "$comment": "Read Discord channel information.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/api/v[0-9]+/channels(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "discord-write-channels": {
    "$comment": "Create, edit, or delete Discord channels.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/api/v[0-9]+/channels(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "discord-read-guilds": {
    "$comment": "Read Discord server (guild) information.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/api/v[0-9]+/guilds(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "discord-write-guilds": {
    "$comment": "Create, edit, or delete Discord servers (guilds).",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/api/v[0-9]+/guilds(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "discord-read-users": {
    "$comment": "Read Discord user information.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/api/v[0-9]+/users(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  }
}
