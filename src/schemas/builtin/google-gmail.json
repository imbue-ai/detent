{
  "google-gmail-api": {
    "$comment": "Any request to the Gmail API.",
    "properties": {
      "domain": {
        "const": "gmail.googleapis.com"
      }
    },
    "required": [
      "domain"
    ]
  },
  "google-gmail-read-all": {
    "$comment": "Read anything from Gmail.",
    "properties": {
      "method": {
        "const": "GET"
      }
    },
    "required": [
      "method"
    ]
  },
  "google-gmail-write-all": {
    "$comment": "Create, update, or delete anything in Gmail.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      }
    },
    "required": [
      "method"
    ]
  },
  "google-gmail-read-messages": {
    "$comment": "List or read messages.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/gmail/v[0-9]+/users/[^/]+/messages(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-gmail-write-messages": {
    "$comment": "Create, update, or delete messages, including uploads.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/(upload/)?gmail/v[0-9]+/users/[^/]+/messages(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-gmail-send-messages": {
    "$comment": "Send messages, including uploads.",
    "properties": {
      "method": {
        "const": "POST"
      },
      "path": {
        "type": "string",
        "pattern": "^/(upload/)?gmail/v[0-9]+/users/[^/]+/messages/send$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
