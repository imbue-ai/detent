{
  "google-sheets-api": {
    "properties": {
      "domain": {
        "const": "sheets.googleapis.com"
      }
    },
    "required": [
      "domain"
    ]
  },
  "google-sheets-read-all": {
    "properties": {
      "method": {
        "const": "GET"
      }
    },
    "required": [
      "method"
    ]
  },
  "google-sheets-write-all": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      }
    },
    "required": [
      "method"
    ]
  },
  "google-sheets-read-spreadsheets": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/spreadsheets/[^/]+$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-sheets-create-spreadsheets": {
    "properties": {
      "method": {
        "const": "POST"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/spreadsheets$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-sheets-update-spreadsheets": {
    "properties": {
      "method": {
        "const": "POST"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/spreadsheets/[^/:]+:batchUpdate$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-sheets-read-values": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/spreadsheets/[^/]+/values(/.+|:.+)$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-sheets-write-values": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/spreadsheets/[^/]+/values(/.+|:.+)$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  }
}
