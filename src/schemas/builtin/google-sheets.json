{
  "google-sheets-api": {
    "$comment": "Any request to the Google Sheets API.",
    "properties": {
      "domain": {
        "const": "sheets.googleapis.com"
      }
    },
    "required": [
      "domain"
    ]
  },
  "google-sheets-read-all": {
    "$comment": "Read anything from Google Sheets.",
    "properties": {
      "method": {
        "const": "GET"
      }
    },
    "required": [
      "method"
    ]
  },
  "google-sheets-write-all": {
    "$comment": "Create, update, or delete anything in Google Sheets.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      }
    },
    "required": [
      "method"
    ]
  },
  "google-sheets-read-spreadsheets": {
    "$comment": "Read spreadsheet metadata (title, sheets, properties, etc.).",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/spreadsheets/[^/]+$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-sheets-create-spreadsheets": {
    "$comment": "Create new spreadsheets.",
    "properties": {
      "method": {
        "const": "POST"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/spreadsheets$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-sheets-update-spreadsheets": {
    "$comment": "Modify spreadsheet structure or formatting via batch updates.",
    "properties": {
      "method": {
        "const": "POST"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/spreadsheets/[^/:]+:batchUpdate$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-sheets-read-values": {
    "$comment": "Read cell values from a spreadsheet.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/spreadsheets/[^/]+/values(/.+|:.+)$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-sheets-write-values": {
    "$comment": "Write or append cell values in a spreadsheet.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/spreadsheets/[^/]+/values(/.+|:.+)$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  }
}
