{
  "google-people-api": {
    "properties": {
      "domain": {
        "const": "people.googleapis.com"
      }
    },
    "required": [
      "domain"
    ]
  },
  "google-people-read-all": {
    "properties": {
      "method": {
        "const": "GET"
      }
    },
    "required": [
      "method"
    ]
  },
  "google-people-write-all": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      }
    },
    "required": [
      "method"
    ]
  },
  "google-people-read-contacts": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/people((/|:).*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-people-write-contacts": {
