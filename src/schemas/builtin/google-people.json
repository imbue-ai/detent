{
  "google-people-api": {
    "$comment": "Any request to the Google People API.",
    "properties": {
      "domain": {
        "const": "people.googleapis.com"
      }
    },
    "required": [
      "domain"
    ]
  },
  "google-people-read-all": {
    "$comment": "Read anything from the Google People API.",
    "properties": {
      "method": {
        "const": "GET"
      }
    },
    "required": [
      "method"
    ]
  },
  "google-people-write-all": {
    "$comment": "Create, update, or delete anything in the Google People API.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      }
    },
    "required": [
      "method"
    ]
  },
  "google-people-read-contacts": {
    "$comment": "List or read contacts.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/people((/|:).*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-people-write-contacts": {
    "$comment": "Create, update, or delete contacts.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/people((/|:).*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-people-read-contact-groups": {
    "$comment": "List or read contact groups.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/contactGroups((/|:).*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-people-write-contact-groups": {
    "$comment": "Create, update, or delete contact groups.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/contactGroups((/|:).*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-people-read-other-contacts": {
    "$comment": "List or read other contacts (contacts outside the user's address book).",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/otherContacts((/|:).*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-people-write-other-contacts": {
    "$comment": "Create, update, or delete other contacts (contacts outside the user's address book).",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/otherContacts((/|:).*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  }
}
