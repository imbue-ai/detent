{
  "stripe-api": {
    "$comment": "Any interaction with the Stripe API.",
    "properties": {
      "domain": {
        "const": "api.stripe.com"
      }
    },
    "required": [
      "domain"
    ]
  },
  "stripe-read-all": {
    "$comment": "Read any Stripe resource.",
    "properties": {
      "method": {
        "const": "GET"
      }
    },
    "required": [
      "method"
    ]
  },
  "stripe-write-all": {
    "$comment": "Create, update, or delete any Stripe resource.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      }
    },
    "required": [
      "method"
    ]
  },
  "stripe-read-customers": {
    "$comment": "View customers.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v1/customers(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "stripe-write-customers": {
    "$comment": "Create, update, or delete customers.",
    "properties": {
      "method": {
        "enum": [
