{
  "calendly-api": {
    "properties": {
      "domain": {
        "const": "api.calendly.com"
      }
    },
    "required": [
      "domain"
    ]
  },
  "calendly-read-all": {
    "properties": {
      "method": {
        "const": "GET"
      }
    },
    "required": [
      "method"
    ]
  },
  "calendly-write-all": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      }
    },
    "required": [
      "method"
    ]
  },
  "calendly-read-scheduled-events": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/(scheduled_events|invitee_no_shows)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "calendly-write-scheduled-events": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/(scheduled_events/[^/]+/cancellation|invitees(/[^/]+/no_show)?|invitee_no_shows(/.*)?)$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "calendly-read-event-types": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/(event_types|event_type_available_times|event_type_memberships)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "calendly-write-event-types": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PATCH"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/(event_types|one_off_event_types)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "calendly-read-availability": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/(user_busy_times|user_availability_schedules|event_type_availability_schedules)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "calendly-write-availability": {
    "properties": {
      "method": {
        "const": "PATCH"
      },
      "path": {
        "type": "string",
        "pattern": "^/event_type_availability_schedules/[^/]+$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "calendly-read-users": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/users(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "calendly-read-organizations": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/(organizations|organization_memberships|organization_invitations)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "calendly-write-organizations": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/(organization_invitations|organization_memberships)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "calendly-read-webhooks": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/webhook_subscriptions(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "calendly-write-webhooks": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/webhook_subscriptions(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "calendly-read-routing-forms": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/(routing_forms|routing_form_submissions)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "calendly-write-scheduling-links": {
    "properties": {
      "method": {
        "const": "POST"
      },
      "path": {
        "type": "string",
        "pattern": "^/scheduling_links$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "calendly-write-shares": {
    "properties": {
      "method": {
        "const": "POST"
      },
      "path": {
        "type": "string",
        "pattern": "^/shares$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "calendly-write-data-compliance": {
    "properties": {
      "method": {
        "const": "POST"
      },
      "path": {
        "type": "string",
        "pattern": "^/data_compliance/(deletion_event|invitee_deletion)$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  }
}
