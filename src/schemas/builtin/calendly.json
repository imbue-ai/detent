{
  "calendly-api": {
    "$comment": "Identifies requests to the Calendly API.",
    "properties": {
      "domain": {
        "const": "api.calendly.com"
      }
    },
    "required": [
      "domain"
    ]
  },
  "calendly-read-all": {
    "$comment": "Read any Calendly resource.",
    "properties": {
      "method": {
        "const": "GET"
      }
    },
    "required": [
      "method"
    ]
  },
  "calendly-write-all": {
    "$comment": "Create, update, or delete any Calendly resource.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      }
    },
    "required": [
      "method"
    ]
  },
  "calendly-read-scheduled-events": {
    "$comment": "View scheduled events and invitee no-shows.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/(scheduled_events|invitee_no_shows)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "calendly-write-scheduled-events": {
    "$comment": "Cancel scheduled events and manage invitee no-shows.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/(scheduled_events/[^/]+/cancellation|invitees(/[^/]+/no_show)?|invitee_no_shows(/.*)?)$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "calendly-read-event-types": {
    "$comment": "View event types, their available times, and memberships.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/(event_types|event_type_available_times|event_type_memberships)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "calendly-write-event-types": {
    "$comment": "Create or update event types, including one-off event types.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PATCH"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/(event_types|one_off_event_types)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "calendly-read-availability": {
    "$comment": "View user busy times and availability schedules.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/(user_busy_times|user_availability_schedules|event_type_availability_schedules)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "calendly-write-availability": {
    "$comment": "Update event type availability schedules.",
    "properties": {
      "method": {
        "const": "PATCH"
      },
      "path": {
        "type": "string",
        "pattern": "^/event_type_availability_schedules/[^/]+$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "calendly-read-users": {
    "$comment": "View user profiles.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/users(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "calendly-read-organizations": {
    "$comment": "View organization details, memberships, and invitations.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/(organizations|organization_memberships|organization_invitations)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "calendly-write-organizations": {
    "$comment": "Create or remove organization invitations and memberships.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/(organization_invitations|organization_memberships)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "calendly-read-webhooks": {
    "$comment": "View webhook subscriptions.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/webhook_subscriptions(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "calendly-write-webhooks": {
    "$comment": "Create or remove webhook subscriptions.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/webhook_subscriptions(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "calendly-read-routing-forms": {
    "$comment": "View routing forms and their submissions.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/(routing_forms|routing_form_submissions)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "calendly-write-scheduling-links": {
    "$comment": "Create scheduling links.",
    "properties": {
      "method": {
        "const": "POST"
      },
      "path": {
        "type": "string",
        "pattern": "^/scheduling_links$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "calendly-write-shares": {
    "$comment": "Create shares.",
    "properties": {
      "method": {
        "const": "POST"
      },
      "path": {
        "type": "string",
        "pattern": "^/shares$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "calendly-write-data-compliance": {
    "$comment": "Request deletion of event or invitee data for compliance purposes.",
    "properties": {
      "method": {
        "const": "POST"
      },
      "path": {
        "type": "string",
        "pattern": "^/data_compliance/(deletion_event|invitee_deletion)$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  }
}
