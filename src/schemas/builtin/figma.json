{
  "figma-api": {
    "properties": {
      "domain": {
        "const": "api.figma.com"
      }
    },
    "required": [
      "domain"
    ]
  },
  "figma-read-all": {
    "properties": {
      "method": {
        "const": "GET"
      }
    },
    "required": [
      "method"
    ]
  },
  "figma-write-all": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      }
    },
    "required": [
      "method"
    ]
  },
  "figma-read-files": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/(files|images)/[^/]+(/nodes|/images|/meta|/versions)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "figma-read-comments": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/files/[^/]+/comments(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "figma-write-comments": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/files/[^/]+/comments(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "figma-read-projects": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/(teams/[^/]+/projects|projects/[^/]+/files)$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "figma-read-components": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/(components/[^/]+|component_sets/[^/]+|styles/[^/]+|teams/[^/]+/(components|component_sets|styles)|files/[^/]+/(components|component_sets|styles))$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "figma-read-webhooks": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/(webhooks|teams/[^/]+/webhooks)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "figma-write-webhooks": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/(webhooks|teams/[^/]+/webhooks)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "figma-read-variables": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/files/[^/]+/variables(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "figma-write-variables": {
    "properties": {
      "method": {
        "const": "POST"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/files/[^/]+/variables$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "figma-read-dev-resources": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/(files/[^/]+/dev_resources|dev_resources)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "figma-write-dev-resources": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/(files/[^/]+/dev_resources|dev_resources)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "figma-read-library-analytics": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/analytics/libraries(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  }
}
