{
  "figma-api": {
    "$comment": "Any request to the Figma API.",
    "properties": {
      "domain": {
        "const": "api.figma.com"
      }
    },
    "required": [
      "domain"
    ]
  },
  "figma-read-all": {
    "$comment": "Read anything from Figma.",
    "properties": {
      "method": {
        "const": "GET"
      }
    },
    "required": [
      "method"
    ]
  },
  "figma-write-all": {
    "$comment": "Create, update, or delete anything in Figma.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      }
    },
    "required": [
      "method"
    ]
  },
  "figma-read-files": {
    "$comment": "Read Figma files, including their images, metadata, and versions.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/(files|images)/[^/]+(/nodes|/images|/meta|/versions)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "figma-read-comments": {
    "$comment": "Read comments on Figma files.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/files/[^/]+/comments(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "figma-write-comments": {
    "$comment": "Post or delete comments on Figma files.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/files/[^/]+/comments(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "figma-read-projects": {
    "$comment": "List team projects and project files.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/(teams/[^/]+/projects|projects/[^/]+/files)$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "figma-read-components": {
    "$comment": "Read components, component sets, and styles from Figma files or teams.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/(components/[^/]+|component_sets/[^/]+|styles/[^/]+|teams/[^/]+/(components|component_sets|styles)|files/[^/]+/(components|component_sets|styles))$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "figma-read-webhooks": {
    "$comment": "List webhooks and read their details.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/(webhooks|teams/[^/]+/webhooks)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "figma-write-webhooks": {
    "$comment": "Create, update, or delete webhooks.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/(webhooks|teams/[^/]+/webhooks)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "figma-read-variables": {
    "$comment": "Read variables from Figma files.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/files/[^/]+/variables(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "figma-write-variables": {
    "$comment": "Create or update variables in Figma files.",
    "properties": {
      "method": {
        "const": "POST"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/files/[^/]+/variables$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "figma-read-dev-resources": {
    "$comment": "Read dev resources from Figma files.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/(files/[^/]+/dev_resources|dev_resources)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "figma-write-dev-resources": {
    "$comment": "Create, update, or delete dev resources in Figma files.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/(files/[^/]+/dev_resources|dev_resources)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "figma-read-library-analytics": {
    "$comment": "Read library usage analytics.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/analytics/libraries(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  }
}
