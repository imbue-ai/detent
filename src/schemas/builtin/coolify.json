{
  "coolify-api": {
    "$comment": "Identifies requests to the Coolify API.",
    "properties": {
      "domain": {
        "const": "app.coolify.io"
      }
    },
    "required": [
      "domain"
    ]
  },
  "coolify-read-all": {
    "$comment": "List and inspect all Coolify resources, excluding actions like start, stop, restart, deploy, and similar operations.",
    "properties": {
      "method": { "const": "GET" }
    },
    "required": ["method"],
    "allOf": [
      {
        "not": {
          "properties": {
            "path": {
              "type": "string",
              "pattern": "^/api/v[0-9]+/.+/(start|stop|restart|cancel|validate)$"
            }
          },
          "required": ["path"]
        }
      },
      {
        "not": {
          "properties": {
            "path": {
              "type": "string",
              "pattern": "^/api/v[0-9]+/(deploy|enable|disable)(/.*)?$"
            }
          },
          "required": ["path"]
        }
      }
    ]
  },
  "coolify-write-all": {
    "$comment": "Create, update, delete, and perform actions (start, stop, restart, deploy, etc.) on all Coolify resources.",
    "anyOf": [
      {
        "properties": {
          "method": {
            "enum": ["POST", "PUT", "PATCH", "DELETE"]
          }
        },
        "required": ["method"]
      },
      {
        "properties": {
          "method": { "const": "GET" },
          "path": {
            "type": "string"
          }
        },
        "required": ["method", "path"],
        "anyOf": [
          {
            "properties": {
              "path": {
                "pattern": "^/api/v[0-9]+/.+/(start|stop|restart|cancel|validate)$"
              }
            }
          },
          {
            "properties": {
              "path": {
                "pattern": "^/api/v[0-9]+/(deploy|enable|disable)(/.*)?$"
              }
            }
          }
        ]
      }
    ]
  },
  "coolify-read-applications": {
    "$comment": "List and inspect applications.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/api/v[0-9]+/applications(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "coolify-write-applications": {
    "$comment": "Create, update, or delete applications.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
