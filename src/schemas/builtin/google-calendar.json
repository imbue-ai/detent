{
  "google-calendar-api": {
    "$comment": "Identify requests to the Google Calendar API.",
    "properties": {
      "domain": {
        "const": "www.googleapis.com"
      },
      "path": {
        "type": "string",
        "pattern": "^/calendar/"
      }
    },
    "required": [
      "domain",
      "path"
    ]
  },
  "google-calendar-read-all": {
    "$comment": "Read any Google Calendar resource.",
    "properties": {
      "method": {
        "const": "GET"
      }
    },
    "required": [
      "method"
    ]
  },
  "google-calendar-write-all": {
    "$comment": "Create, update, or delete any Google Calendar resource.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      }
    },
    "required": [
      "method"
    ]
  },
  "google-calendar-read-events": {
    "$comment": "Read events from calendars.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/calendar/v[0-9]+/calendars/[^/]+/events(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-calendar-write-events": {
    "$comment": "Create, update, or delete events on calendars.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/calendar/v[0-9]+/calendars/[^/]+/events(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-calendar-read-calendars": {
    "$comment": "Read calendar details.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/calendar/v[0-9]+/calendars/[^/]+$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-calendar-write-calendars": {
    "$comment": "Create, update, delete, or clear calendars.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/calendar/v[0-9]+/calendars(/[^/]+(/clear)?)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-calendar-read-calendar-list": {
    "$comment": "Read the user's list of calendars.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/calendar/v[0-9]+/users/me/calendarList(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-calendar-write-calendar-list": {
    "$comment": "Add, update, or remove calendars from the user's calendar list.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/calendar/v[0-9]+/users/me/calendarList(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-calendar-read-settings": {
    "$comment": "Read the user's calendar settings.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/calendar/v[0-9]+/users/me/settings(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-calendar-read-acl": {
    "$comment": "Read access control rules on calendars.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/calendar/v[0-9]+/calendars/[^/]+/acl(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-calendar-write-acl": {
    "$comment": "Create, update, or delete access control rules on calendars.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/calendar/v[0-9]+/calendars/[^/]+/acl(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-calendar-query-freebusy": {
    "$comment": "Query free/busy information for calendars.",
    "properties": {
      "method": {
        "const": "POST"
      },
      "path": {
        "type": "string",
        "pattern": "^/calendar/v[0-9]+/freeBusy$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-calendar-read-colors": {
    "$comment": "Read available calendar and event colors.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/calendar/v[0-9]+/colors$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  }
}
