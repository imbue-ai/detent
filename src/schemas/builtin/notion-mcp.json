{
  "notion-mcp-api": {
    "$comment": "Any request to Notion's hosted MCP endpoint (mcp.notion.com).",
    "properties": {
      "domain": {
        "const": "mcp.notion.com"
      }
    },
    "required": [
      "domain"
    ]
  },
  "notion-mcp-session": {
    "$comment": "Open and maintain an MCP session: initialize, list tools/prompts/resources, ping, and send notifications. Required for any MCP client to function; does not read or modify Notion content.",
    "properties": {
      "method": {
        "const": "POST"
      },
      "path": {
        "type": "string",
        "pattern": "^/mcp/?$"
      },
      "body": {
        "type": "string",
        "pattern": "\"method\"\\s*:\\s*\"(initialize|notifications/[A-Za-z/]+|ping|tools/list|prompts/(list|get)|resources/(list|read|templates/list)|completion/complete|logging/setLevel)\""
      }
    },
    "required": [
      "method",
      "path",
      "body"
    ]
  },
  "notion-mcp-read-all": {
    "$comment": "Run any read-only Notion MCP tool (search, fetch, queries, list users/teams/comments) plus the MCP session handshake.",
    "properties": {
      "method": {
        "const": "POST"
      },
      "path": {
        "type": "string",
        "pattern": "^/mcp/?$"
      }
    },
    "required": [
      "method",
      "path",
      "body"
    ],
    "anyOf": [
      {
        "properties": {
          "body": {
            "type": "string",
            "pattern": "\"method\"\\s*:\\s*\"(initialize|notifications/[A-Za-z/]+|ping|tools/list|prompts/(list|get)|resources/(list|read|templates/list)|completion/complete|logging/setLevel)\""
          }
        }
      },
      {
        "properties": {
          "body": {
            "type": "string",
            "pattern": "(?=[\\s\\S]*\"method\"\\s*:\\s*\"tools/call\")(?=[\\s\\S]*\"name\"\\s*:\\s*\"(notion-search|notion-fetch|notion-query-data-sources|notion-query-database-view|notion-get-comments|notion-get-teams|notion-get-users|notion-get-user|notion-get-self)\")"
          }
        }
      }
    ]
  },
  "notion-mcp-write-all": {
    "$comment": "Run any Notion MCP tool that creates or modifies content (create/update pages, databases, views, data sources, comments; move/duplicate pages) plus the MCP session handshake.",
    "properties": {
      "method": {
        "const": "POST"
