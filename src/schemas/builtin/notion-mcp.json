            "pattern": "\"method\"\\s*:\\s*\"(initialize|notifications/[A-Za-z/]+|ping|tools/list|prompts/(list|get)|resources/(list|read|templates/list)|completion/complete|logging/setLevel)\""
          }
        }
      },
      {
        "properties": {
          "body": {
            "type": "string",
            "pattern": "(?=[\\s\\S]*\"method\"\\s*:\\s*\"tools/call\")(?=[\\s\\S]*\"name\"\\s*:\\s*\"(notion-create-pages|notion-update-page|notion-move-pages|notion-duplicate-page|notion-create-database|notion-update-data-source|notion-create-view|notion-update-view|notion-create-comment)\")"
          }
        }
      }
    ]
  },
