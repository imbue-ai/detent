{
  "notion-mcp-api": {
    "$comment": "Any request to Notion's hosted MCP endpoint (mcp.notion.com).",
    "properties": {
      "domain": {
        "const": "mcp.notion.com"
      }
    },
    "required": [
      "domain"
    ]
  },
  "notion-mcp-session": {
    "$comment": "Open and maintain an MCP session: initialize, list tools/prompts/resources, ping, and send notifications. Required for any MCP client to function; does not read or modify Notion content.",
    "properties": {
      "method": {
        "const": "POST"
      },
      "path": {
        "type": "string",
        "pattern": "^/mcp/?$"
      },
      "parsedBody": {
        "type": "object",
        "properties": {
          "method": {
            "enum": [
              "initialize",
              "notifications/initialized",
              "notifications/cancelled",
              "ping",
              "tools/list",
              "prompts/list",
              "prompts/get",
              "resources/list",
              "resources/read",
              "resources/templates/list",
              "resources/subscribe",
              "resources/unsubscribe",
              "completion/complete",
              "logging/setLevel"
            ]
          }
        },
        "required": [
          "method"
        ]
      }
    },
    "required": [
      "method",
      "path",
      "parsedBody"
    ]
  },
  "notion-mcp-read-all": {
    "$comment": "Run any read-only Notion MCP tool (search, fetch, queries, list comments/teams, bot info) plus the MCP session handshake.",
    "properties": {
      "method": {
        "const": "POST"
      },
      "path": {
        "type": "string",
        "pattern": "^/mcp/?$"
      },
      "parsedBody": {
        "type": "object",
        "anyOf": [
          {
            "type": "object",
            "properties": {
              "method": {
                "enum": [
                  "initialize",
                  "notifications/initialized",
                  "notifications/cancelled",
                  "ping",
                  "tools/list",
                  "prompts/list",
                  "prompts/get",
                  "resources/list",
                  "resources/read",
                  "resources/templates/list",
                  "resources/subscribe",
                  "resources/unsubscribe",
                  "completion/complete",
                  "logging/setLevel"
                ]
              }
            },
            "required": [
              "method"
            ]
          },
          {
            "type": "object",
            "properties": {
              "method": {
                "const": "tools/call"
              },
              "params": {
                "type": "object",
                "properties": {
                  "name": {
                    "enum": [
                      "notion-search",
                      "notion-fetch",
                      "notion-query-data-sources",
                      "notion-query-database-view",
                      "notion-get-comments",
                      "notion-get-teams",
                      "notion-get-self"
                    ]
                  }
                },
                "required": [
                  "name"
                ]
              }
            },
            "required": [
              "method",
              "params"
            ]
          }
        ]
      }
    },
    "required": [
      "method",
      "path",
      "parsedBody"
    ]
  },
