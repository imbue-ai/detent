{
  "slack-api": {
    "$comment": "Any interaction with the Slack API.",
    "properties": {
      "domain": {
        "const": "slack.com"
      }
    },
    "required": [
      "domain"
    ]
  },
  "slack-read-all": {
    "$comment": "All read operations across the entire Slack API, including messages, users, files, reactions, search, pins, bookmarks, and reminders.",
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/api/(auth\\.(test|teams\\.list)|chat\\.(getPermalink|scheduledMessages\\.list)|conversations\\.(history|info|list|listConnectInvites|members|replies|requestSharedInvite\\.list)|users\\.(conversations|getPresence|identity|info|list|lookupByEmail|profile\\.get)|files\\.(info|list|remote\\.(info|list))|reactions\\.(get|list)|search\\.(all|files|messages)|pins\\.list|bookmarks\\.list|reminders\\.(info|list))$"
      }
    },
    "required": [
      "path"
    ]
  },
  "slack-write-all": {
    "$comment": "All write operations across the entire Slack API, including sending messages, managing conversations, updating profiles, uploading files, and modifying pins, bookmarks, and reminders.",
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/api/(auth\\.revoke|chat\\.(appendStream|delete|deleteScheduledMessage|meMessage|postEphemeral|postMessage|scheduleMessage|startStream|stopStream|unfurl|update)|conversations\\.(acceptSharedInvite|approveSharedInvite|archive|canvasCreate|close|create|declineSharedInvite|externalInvitePermissions\\.set|invite|inviteShared|join|kick|leave|mark|open|rename|requestSharedInvite\\.(approve|deny)|setPurpose|setTopic|unarchive)|users\\.(setPresence|profile\\.set)|files\\.(completeUploadExternal|delete|getUploadURLExternal|remote\\.(add|remove|share|update)|revokePublicURL|sharedPublicURL)|reactions\\.(add|remove)|pins\\.(add|remove)|bookmarks\\.(add|edit|remove)|reminders\\.(add|complete|delete))$"
      }
    },
    "required": [
      "path"
    ]
  },
  "slack-auth-read": {
    "$comment": "Check authentication status and list teams.",
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/api/auth\\.(test|teams\\.list)$"
      }
    },
    "required": [
      "path"
    ]
  },
  "slack-auth-write": {
    "$comment": "Revoke authentication tokens.",
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/api/auth\\.revoke$"
      }
    },
    "required": [
      "path"
    ]
  },
  "slack-chat-read": {
    "$comment": "Get message permalinks and list scheduled messages.",
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/api/chat\\.(getPermalink|scheduledMessages\\.list)$"
      }
    },
    "required": [
      "path"
    ]
  },
  "slack-chat-write": {
    "$comment": "Send, update, delete, and schedule messages.",
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/api/chat\\.(appendStream|delete|deleteScheduledMessage|meMessage|postEphemeral|postMessage|scheduleMessage|startStream|stopStream|unfurl|update)$"
      }
    },
    "required": [
      "path"
    ]
  },
  "slack-conversations-read": {
    "$comment": "Read conversation history, details, members, and replies.",
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/api/conversations\\.(history|info|list|listConnectInvites|members|replies|requestSharedInvite\\.list)$"
      }
    },
    "required": [
      "path"
    ]
  },
  "slack-conversations-write": {
    "$comment": "Create, archive, rename, and manage conversations, including membership, invitations, topics, and purposes.",
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/api/conversations\\.(acceptSharedInvite|approveSharedInvite|archive|canvasCreate|close|create|declineSharedInvite|externalInvitePermissions\\.set|invite|inviteShared|join|kick|leave|mark|open|rename|requestSharedInvite\\.(approve|deny)|setPurpose|setTopic|unarchive)$"
      }
    },
    "required": [
      "path"
    ]
  },
  "slack-users-read": {
    "$comment": "Read user profiles, presence, identity, and look up users by email.",
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/api/users\\.(conversations|getPresence|identity|info|list|lookupByEmail|profile\\.get)$"
      }
    },
    "required": [
      "path"
    ]
  },
  "slack-users-write": {
    "$comment": "Update user presence and profile information.",
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/api/users\\.(setPresence|profile\\.set)$"
      }
    },
    "required": [
      "path"
    ]
  },
  "slack-files-read": {
    "$comment": "List and inspect files, including remote files.",
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/api/files\\.(info|list|remote\\.(info|list))$"
      }
    },
    "required": [
      "path"
    ]
  },
  "slack-files-write": {
    "$comment": "Upload, delete, and share files, including remote files.",
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/api/files\\.(completeUploadExternal|delete|getUploadURLExternal|remote\\.(add|remove|share|update)|revokePublicURL|sharedPublicURL)$"
      }
    },
    "required": [
      "path"
    ]
  },
  "slack-reactions-read": {
    "$comment": "List and inspect emoji reactions on messages.",
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/api/reactions\\.(get|list)$"
      }
    },
    "required": [
      "path"
    ]
  },
  "slack-reactions-write": {
    "$comment": "Add or remove emoji reactions.",
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/api/reactions\\.(add|remove)$"
      }
    },
    "required": [
      "path"
    ]
  },
  "slack-search": {
    "$comment": "Search messages, files, and all content.",
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/api/search\\.(all|files|messages)$"
      }
    },
    "required": [
      "path"
    ]
  },
  "slack-pins-read": {
    "$comment": "List pinned messages in a conversation.",
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/api/pins\\.list$"
      }
    },
    "required": [
      "path"
    ]
  },
  "slack-pins-write": {
    "$comment": "Pin or unpin messages in a conversation.",
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/api/pins\\.(add|remove)$"
      }
    },
    "required": [
      "path"
    ]
  },
  "slack-bookmarks-read": {
    "$comment": "List bookmarks in a conversation.",
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/api/bookmarks\\.list$"
      }
    },
    "required": [
      "path"
    ]
  },
  "slack-bookmarks-write": {
    "$comment": "Add, edit, or remove bookmarks.",
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/api/bookmarks\\.(add|edit|remove)$"
      }
    },
    "required": [
      "path"
    ]
  },
  "slack-reminders-read": {
    "$comment": "List and inspect reminders.",
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/api/reminders\\.(info|list)$"
      }
    },
    "required": [
      "path"
    ]
  },
  "slack-reminders-write": {
    "$comment": "Create, complete, or delete reminders.",
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/api/reminders\\.(add|complete|delete)$"
      }
    },
    "required": [
      "path"
    ]
  }
}
