{
  "aws": {
    "$comment": "Any access to AWS services.",
    "properties": {
      "domain": {
        "type": "string",
        "pattern": "^([a-z0-9.-]+\\.)?amazonaws\\.com$"
      }
    },
    "required": [
      "domain"
    ]
  },
  "aws-s3": {
    "$comment": "Any access to AWS S3 object storage.",
    "properties": {
      "domain": {
        "type": "string",
        "pattern": "^(.*\\.)?s3(-[a-z]+)?(\\.[a-z0-9.-]+)?\\.amazonaws\\.com$"
      }
    },
    "required": [
      "domain"
    ]
  },
  "aws-s3-read": {
    "$comment": "Read objects and metadata from AWS S3.",
    "properties": {
      "domain": {
        "type": "string",
        "pattern": "^(.*\\.)?s3(-[a-z]+)?(\\.[a-z0-9.-]+)?\\.amazonaws\\.com$"
      },
      "method": {
        "enum": [
          "GET",
          "HEAD"
        ]
      }
    },
    "required": [
      "domain",
      "method"
    ]
  },
  "aws-s3-write": {
    "$comment": "Create, update, and delete objects in AWS S3.",
    "properties": {
      "domain": {
        "type": "string",
        "pattern": "^(.*\\.)?s3(-[a-z]+)?(\\.[a-z0-9.-]+)?\\.amazonaws\\.com$"
      },
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      }
    },
    "required": [
      "domain",
      "method"
    ]
  },
