    "properties": {
      "domain": {
        "type": "string",
        "pattern": "^(.*\\.)?s3(-[a-z]+)?(\\.[a-z0-9.-]+)?\\.amazonaws\\.com$"
      }
    },
    "required": [
      "domain"
    ]
  },
