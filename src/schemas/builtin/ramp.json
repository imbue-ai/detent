{
  "ramp-api": {
    "$comment": "Any request to the Ramp developer API.",
    "properties": {
      "domain": {
        "const": "api.ramp.com"
      }
    },
    "required": [
      "domain"
    ]
  },
  "ramp-read-all": {
    "$comment": "Read anything from Ramp.",
    "properties": {
      "method": {
        "const": "GET"
      }
    },
    "required": [
      "method"
    ]
  },
  "ramp-write-all": {
    "$comment": "Create, update, or delete anything in Ramp.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      }
    },
    "required": [
      "method"
    ]
  },
  "ramp-read-transactions": {
    "$comment": "Read card transactions.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/developer/v[0-9]+/transactions(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
