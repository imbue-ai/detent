{
  "mailchimp-api": {
    "$comment": "Any request to the Mailchimp API.",
    "properties": {
      "domain": {
        "type": "string",
        "pattern": "^([^.]+\\.)?api\\.mailchimp\\.com$"
      }
    },
    "required": [
      "domain"
    ]
  },
  "mailchimp-read-all": {
    "$comment": "Read any Mailchimp resource.",
    "properties": {
      "method": {
        "const": "GET"
      }
    },
    "required": [
      "method"
    ]
  },
  "mailchimp-write-all": {
    "$comment": "Create, update, or delete any Mailchimp resource.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      }
    },
    "required": [
      "method"
    ]
  },
  "mailchimp-read-campaigns": {
    "$comment": "Read Mailchimp campaigns.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/[0-9.]+/campaigns(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "mailchimp-write-campaigns": {
    "$comment": "Create, update, or delete Mailchimp campaigns.",
