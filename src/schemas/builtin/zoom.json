{
  "zoom-api": {
    "$comment": "Requests to the Zoom API.",
    "properties": {
      "domain": {
        "const": "api.zoom.us"
      }
    },
    "required": [
      "domain"
    ]
  },
  "zoom-read-all": {
    "$comment": "Read any Zoom data.",
    "properties": {
      "method": {
        "const": "GET"
      }
    },
    "required": [
      "method"
    ]
  },
  "zoom-write-all": {
    "$comment": "Create, update, or delete any Zoom data.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      }
    },
    "required": [
      "method"
    ]
  },
  "zoom-read-meetings": {
    "$comment": "View meetings and meeting details.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/(meetings|past_meetings|live_meetings|users/[^/]+/meetings|users/[^/]+/upcoming_meetings)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "zoom-write-meetings": {
    "$comment": "Create, update, or delete meetings.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/(meetings|past_meetings|live_meetings|users/[^/]+/meetings|users/[^/]+/upcoming_meetings)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "zoom-read-webinars": {
    "$comment": "View webinars and webinar details.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/(webinars|past_webinars|live_webinars|users/[^/]+/webinars)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "zoom-write-webinars": {
    "$comment": "Create, update, or delete webinars.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/(webinars|past_webinars|live_webinars|users/[^/]+/webinars)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "zoom-read-recordings": {
    "$comment": "View meeting and user recordings.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/(meetings/[^/]+/recordings|users/[^/]+/recordings)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "zoom-write-recordings": {
    "$comment": "Create, update, or delete meeting and user recordings.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/(meetings/[^/]+/recordings|users/[^/]+/recordings)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "zoom-read-reports": {
    "$comment": "View reports and report data.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/report(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "zoom-read-users": {
    "$comment": "View user profiles and details.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/users(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "zoom-write-users": {
    "$comment": "Create, update, or delete users.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/users(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  }
}
