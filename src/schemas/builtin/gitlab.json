{
  "gitlab-api": {
    "$comment": "Any request to GitLab.",
    "properties": {
      "domain": {
        "const": "gitlab.com"
      }
    },
    "required": [
      "domain"
    ]
  },
  "gitlab-git": {
    "$comment": "Git operations (clone, fetch, push) on GitLab repositories.",
    "properties": {
      "domain": {
        "const": "gitlab.com"
      },
      "path": {
        "type": "string",
        "pattern": "^/[^/]+(/[^/]+)+/(info/refs|git-upload-pack|git-receive-pack)$"
      }
    },
    "required": [
      "domain",
      "path"
    ]
  },
  "gitlab-git-read": {
    "$comment": "Read-only Git operations (clone, fetch) on GitLab repositories.",
    "anyOf": [
      {
        "properties": {
          "method": {
            "const": "GET"
          },
          "path": {
            "type": "string",
            "pattern": "^/[^/]+(/[^/]+)+/info/refs$"
          },
          "queryParams": {
            "properties": {
              "service": {
                "const": "git-upload-pack"
              }
            },
            "required": [
              "service"
            ]
          }
        },
        "required": [
          "method",
          "path",
          "queryParams"
        ]
      },
      {
        "properties": {
          "method": {
            "const": "POST"
          },
          "path": {
            "type": "string",
            "pattern": "^/[^/]+(/[^/]+)+/git-upload-pack$"
          }
        },
        "required": [
          "method",
          "path"
        ]
      }
    ]
  },
  "gitlab-git-write": {
    "$comment": "Git push operations on GitLab repositories.",
    "anyOf": [
      {
        "properties": {
          "method": {
            "const": "GET"
          },
          "path": {
            "type": "string",
            "pattern": "^/[^/]+(/[^/]+)+/info/refs$"
          },
          "queryParams": {
            "properties": {
              "service": {
                "const": "git-receive-pack"
              }
            },
            "required": [
              "service"
            ]
          }
        },
        "required": [
          "method",
          "path",
          "queryParams"
        ]
      },
      {
        "properties": {
          "method": {
            "const": "POST"
          },
          "path": {
            "type": "string",
            "pattern": "^/[^/]+(/[^/]+)+/git-receive-pack$"
          }
        },
        "required": [
          "method",
          "path"
        ]
      }
    ]
  },
  "gitlab-read-all": {
    "$comment": "Any read-only action on GitLab.",
    "properties": {
      "method": {
        "const": "GET"
      }
    },
    "required": [
      "method"
    ]
  },
  "gitlab-write-all": {
    "$comment": "Any write action on GitLab.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      }
    },
    "required": [
      "method"
    ]
  },
  "gitlab-read-projects": {
    "$comment": "List or view GitLab projects.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/api/v[0-9]+/projects(/[^/]+)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "gitlab-write-projects": {
    "$comment": "Create, update, or delete GitLab projects.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/api/v[0-9]+/projects(/[^/]+)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "gitlab-read-repository": {
    "$comment": "View repository contents, branches, tags, and commits on GitLab.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/api/v[0-9]+/projects/[^/]+/repository(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "gitlab-write-repository": {
    "$comment": "Modify repository contents, branches, tags, or commits on GitLab.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/api/v[0-9]+/projects/[^/]+/repository(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "gitlab-read-merge-requests": {
