{
  "gitlab-api": {
    "properties": {
      "domain": {
        "const": "gitlab.com"
      }
    },
    "required": [
      "domain"
    ]
  },
  "gitlab-git": {
    "properties": {
      "domain": {
        "const": "gitlab.com"
      },
      "path": {
        "type": "string",
        "pattern": "^/[^/]+(/[^/]+)+/(info/refs|git-upload-pack|git-receive-pack)$"
      }
    },
    "required": [
      "domain",
      "path"
    ]
  },
  "gitlab-git-read": {
    "anyOf": [
      {
        "properties": {
          "method": {
            "const": "GET"
          },
          "path": {
            "type": "string",
            "pattern": "^/[^/]+(/[^/]+)+/info/refs$"
          },
          "queryParams": {
            "properties": {
              "service": {
                "const": "git-upload-pack"
              }
            },
            "required": [
              "service"
            ]
          }
        },
        "required": [
          "method",
          "path",
          "queryParams"
        ]
      },
      {
        "properties": {
          "method": {
            "const": "POST"
          },
          "path": {
            "type": "string",
            "pattern": "^/[^/]+(/[^/]+)+/git-upload-pack$"
          }
        },
        "required": [
          "method",
          "path"
        ]
      }
    ]
  },
  "gitlab-git-write": {
    "anyOf": [
      {
        "properties": {
          "method": {
            "const": "GET"
          },
          "path": {
            "type": "string",
            "pattern": "^/[^/]+(/[^/]+)+/info/refs$"
          },
          "queryParams": {
            "properties": {
              "service": {
                "const": "git-receive-pack"
              }
            },
            "required": [
              "service"
            ]
          }
        },
        "required": [
          "method",
          "path",
          "queryParams"
        ]
      },
      {
        "properties": {
          "method": {
            "const": "POST"
          },
          "path": {
            "type": "string",
            "pattern": "^/[^/]+(/[^/]+)+/git-receive-pack$"
          }
        },
        "required": [
          "method",
          "path"
        ]
      }
    ]
  },
  "gitlab-read-all": {
    "properties": {
      "method": {
        "const": "GET"
      }
    },
    "required": [
      "method"
    ]
  },
  "gitlab-write-all": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      }
    },
    "required": [
      "method"
    ]
  },
  "gitlab-read-projects": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/api/v[0-9]+/projects(/[^/]+)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
