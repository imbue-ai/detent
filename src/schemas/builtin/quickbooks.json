{
  "quickbooks-api": {
    "$comment": "Any request to the QuickBooks Online API, in production or sandbox.",
    "properties": {
      "domain": {
        "type": "string",
        "pattern": "^(sandbox-)?quickbooks\\.api\\.intuit\\.com$"
      }
    },
    "required": [
      "domain"
    ]
  },
  "quickbooks-read-all": {
    "$comment": "Read anything from QuickBooks.",
    "properties": {
      "method": {
        "const": "GET"
      }
    },
    "required": [
      "method"
    ]
  },
  "quickbooks-write-all": {
    "$comment": "Create, update, or delete anything in QuickBooks.",
    "properties": {
      "method": {
        "enum": [
          "POST",
          "DELETE"
        ]
      }
    },
    "required": [
      "method"
    ]
  },
  "quickbooks-query": {
    "$comment": "Run read-only queries to list or search records.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v3/company/[^/]+/query$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "quickbooks-read-reports": {
    "$comment": "Read financial reports such as profit and loss or balance sheet.",
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v3/company/[^/]+/reports(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
