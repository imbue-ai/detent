{
  "google-directions-api": {
    "properties": {
      "domain": {
        "const": "routes.googleapis.com"
      }
    },
    "required": [
      "domain"
    ]
  },
  "google-directions-read-all": {
    "properties": {
      "method": {
        "const": "GET"
      }
    },
    "required": [
      "method"
    ]
  },
  "google-directions-write-all": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      }
    },
    "required": [
      "method"
    ]
  },
  "google-directions-compute-routes": {
    "properties": {
      "method": {
        "const": "POST"
      },
      "path": {
        "type": "string",
        "pattern": "^/directions/v[0-9]+:computeRoutes$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-directions-compute-route-matrix": {
    "properties": {
      "method": {
        "const": "POST"
      },
      "path": {
        "type": "string",
        "pattern": "^/distanceMatrix/v[0-9]+:computeRouteMatrix$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  }
}
