{
  "google-docs-api": {
    "properties": {
      "domain": {
        "const": "docs.googleapis.com"
      }
    },
    "required": [
      "domain"
    ]
  },
  "google-docs-read-all": {
    "properties": {
      "method": {
        "const": "GET"
      }
    },
    "required": [
      "method"
    ]
  },
  "google-docs-write-all": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      }
    },
    "required": [
      "method"
    ]
  },
  "google-docs-read-documents": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/documents/[^/]+$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-docs-write-documents": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/documents(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-docs-create-documents": {
    "properties": {
      "method": {
        "const": "POST"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/documents$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-docs-update-documents": {
    "properties": {
      "method": {
        "const": "POST"
      },
      "path": {
        "type": "string",
        "pattern": "^/v[0-9]+/documents/[^/]+:batchUpdate$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  }
}
