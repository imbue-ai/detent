{
  "gitlab-api": {
    "properties": {
      "domain": {
        "const": "gitlab.com"
      }
    },
    "required": [
      "domain"
    ]
  },
  "gitlab-read-all": {
    "properties": {
      "method": {
        "const": "GET"
      }
    },
    "required": [
      "method"
    ]
  },
  "gitlab-write-all": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      }
    },
    "required": [
      "method"
    ]
  },
  "gitlab-read-projects": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/api/v[0-9]+/projects(/[^/]+)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "gitlab-write-projects": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/api/v[0-9]+/projects(/[^/]+)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "gitlab-read-repository": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/api/v[0-9]+/projects/[^/]+/repository(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "gitlab-write-repository": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/api/v[0-9]+/projects/[^/]+/repository(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "gitlab-read-merge-requests": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/api/v[0-9]+/(projects/[^/]+/)?merge_requests(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "gitlab-write-merge-requests": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/api/v[0-9]+/(projects/[^/]+/)?merge_requests(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "gitlab-read-issues": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/api/v[0-9]+/((projects|groups)/[^/]+/)?issues(/.*)?$"
