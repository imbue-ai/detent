{
  "google-calendar-api": {
    "properties": {
      "domain": {
        "const": "www.googleapis.com"
      },
      "path": {
        "type": "string",
        "pattern": "^/calendar/"
      }
    },
    "required": [
      "domain",
      "path"
    ]
  },
  "google-calendar-read-all": {
    "properties": {
      "method": {
        "const": "GET"
      }
    },
    "required": [
      "method"
    ]
  },
  "google-calendar-write-all": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      }
    },
    "required": [
      "method"
    ]
  },
  "google-calendar-read-events": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/calendar/v[0-9]+/calendars/[^/]+/events(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-calendar-write-events": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/calendar/v[0-9]+/calendars/[^/]+/events(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-calendar-read-calendars": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/calendar/v[0-9]+/calendars/[^/]+$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-calendar-write-calendars": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/calendar/v[0-9]+/calendars(/[^/]+(/clear)?)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-calendar-read-calendar-list": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/calendar/v[0-9]+/users/me/calendarList(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-calendar-write-calendar-list": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/calendar/v[0-9]+/users/me/calendarList(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-calendar-read-settings": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/calendar/v[0-9]+/users/me/settings(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-calendar-read-acl": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/calendar/v[0-9]+/calendars/[^/]+/acl(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-calendar-write-acl": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/calendar/v[0-9]+/calendars/[^/]+/acl(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-calendar-query-freebusy": {
    "properties": {
      "method": {
        "const": "POST"
      },
      "path": {
        "type": "string",
        "pattern": "^/calendar/v[0-9]+/freeBusy$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-calendar-read-colors": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/calendar/v[0-9]+/colors$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  }
}
