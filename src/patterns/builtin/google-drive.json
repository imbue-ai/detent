{
  "google-drive-api": {
    "properties": {
      "domain": {
        "const": "www.googleapis.com"
      },
      "path": {
        "type": "string",
        "pattern": "^/(upload/)?drive/"
      }
    },
    "required": [
      "domain",
      "path"
    ]
  },
  "google-drive-read-all": {
    "properties": {
      "method": {
        "const": "GET"
      }
    },
    "required": [
      "method"
    ]
  },
  "google-drive-write-all": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      }
    },
    "required": [
      "method"
    ]
  },
  "google-drive-read-files": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/drive/v[0-9]+/files(/[^/]+)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-drive-write-files": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/(upload/)?drive/v[0-9]+/files(/[^/]+)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-drive-read-permissions": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/drive/v[0-9]+/files/[^/]+/permissions(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-drive-write-permissions": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/drive/v[0-9]+/files/[^/]+/permissions(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-drive-read-comments": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/drive/v[0-9]+/files/[^/]+/comments(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-drive-write-comments": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/drive/v[0-9]+/files/[^/]+/comments(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-drive-read-about": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/drive/v[0-9]+/about$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  }
}
