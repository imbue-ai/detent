  "mailchimp-api": {
    "properties": {
      "domain": {
        "type": "string",
        "pattern": "^([^.]+\\.)?api\\.mailchimp\\.com$"
      }
    },
    "required": [
      "domain"
    ]
  },
  "mailchimp-read-all": {
    "properties": {
      "method": {
        "const": "GET"
      }
    },
    "required": [
      "method"
    ]
  },
