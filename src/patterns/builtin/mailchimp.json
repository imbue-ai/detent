{
  "mailchimp-api": {
    "domain": {
      "type": "string",
      "pattern": "^([^.]+\\.)?api\\.mailchimp\\.com$"
    }
  },
  "mailchimp-read-all": {
    "method": {
      "const": "GET"
    }
  },
  "mailchimp-write-all": {
    "method": {
      "enum": ["POST", "PUT", "PATCH", "DELETE"]
    }
  },
  "mailchimp-read-campaigns": {
    "method": {
      "const": "GET"
    },
    "path": {
      "type": "string",
      "pattern": "^/[0-9.]+/campaigns(/.*)?$"
    }
  },
  "mailchimp-write-campaigns": {
    "method": {
      "enum": ["POST", "PUT", "PATCH", "DELETE"]
    },
