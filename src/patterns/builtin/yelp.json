{
  "yelp-api": {
    "properties": {
      "domain": {
        "const": "api.yelp.com"
      }
    },
    "required": [
      "domain"
    ]
  },
  "yelp-read-all": {
    "properties": {
      "method": {
        "const": "GET"
      }
    },
    "required": [
      "method"
    ]
  },
  "yelp-write-all": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      }
    },
    "required": [
      "method"
    ]
  },
  "yelp-read-businesses": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v3/(businesses|transactions)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "yelp-write-businesses": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/v3/(businesses|transactions)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "yelp-read-reviews": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v3/businesses/[^/]+/(reviews|review_highlights)(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "yelp-read-events": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v3/events(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "yelp-read-categories": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v3/categories(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "yelp-autocomplete": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v3/autocomplete$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "yelp-ai-chat": {
    "properties": {
      "method": {
        "const": "POST"
      },
      "path": {
        "type": "string",
        "pattern": "^/ai/chat(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  }
}
