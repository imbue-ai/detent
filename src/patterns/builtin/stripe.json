{
  "stripe": {
    "domain": {
      "const": "api.stripe.com"
    }
  },
  "stripe-read-all": {
    "method": {
      "const": "GET"
    }
  },
  "stripe-write-all": {
    "method": {
      "enum": ["POST", "PUT", "PATCH", "DELETE"]
    }
  },
  "stripe-read-customers": {
    "method": {
      "const": "GET"
    },
    "path": {
      "type": "string",
      "pattern": "^/v1/customers(/.*)?$"
    }
  },
