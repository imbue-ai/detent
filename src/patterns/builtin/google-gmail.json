{
  "google-gmail-api": {
    "properties": {
      "domain": {
        "const": "gmail.googleapis.com"
      }
    },
    "required": [
      "domain"
    ]
  },
  "google-gmail-read-all": {
    "properties": {
      "method": {
        "const": "GET"
      }
    },
    "required": [
      "method"
    ]
  },
  "google-gmail-write-all": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      }
    },
    "required": [
      "method"
    ]
  },
  "google-gmail-read-messages": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/gmail/v[0-9]+/users/[^/]+/messages(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-gmail-write-messages": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/(upload/)?gmail/v[0-9]+/users/[^/]+/messages(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "google-gmail-send-messages": {
    "properties": {
      "method": {
        "const": "POST"
      },
