{
  "google-gmail": {
    "domain": {
      "const": "gmail.googleapis.com"
    }
  },
  "gmail-read-all": {
    "method": {
      "const": "GET"
    }
  },
  "gmail-write-all": {
    "method": {
      "enum": ["POST", "PUT", "PATCH", "DELETE"]
    }
  },
  "gmail-read-messages": {
    "method": {
      "const": "GET"
    },
    "path": {
      "type": "string",
      "pattern": "^/gmail/v[0-9]+/users/[^/]+/messages(/.*)?$"
    }
  },
  "gmail-write-messages": {
    "method": {
      "enum": ["POST", "PUT", "PATCH", "DELETE"]
    },
