{
  "aws": {
    "domain": {
      "type": "string",
      "pattern": "^([a-z0-9.-]+\\.)?amazonaws\\.com$"
    }
  },
  "aws-read-all": {
    "method": {
      "enum": ["GET", "HEAD"]
    }
  },
  "aws-write-all": {
    "method": {
      "enum": ["POST", "PUT", "PATCH", "DELETE"]
    }
  },
  "aws-s3": {
    "domain": {
      "type": "string",
      "pattern": "^(.*\\.)?s3(-[a-z]+)?(\\.[a-z0-9.-]+)?\\.amazonaws\\.com$"
    }
  },
  "aws-s3-read": {
    "domain": {
      "type": "string",
      "pattern": "^(.*\\.)?s3(-[a-z]+)?(\\.[a-z0-9.-]+)?\\.amazonaws\\.com$"
    },
    "method": {
      "enum": ["GET", "HEAD"]
    }
  },
  "aws-s3-write": {
    "domain": {
      "type": "string",
      "pattern": "^(.*\\.)?s3(-[a-z]+)?(\\.[a-z0-9.-]+)?\\.amazonaws\\.com$"
    },
