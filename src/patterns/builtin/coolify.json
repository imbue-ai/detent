{
  "coolify-api": {
    "domain": {
      "const": "app.coolify.io"
    }
  },
  "coolify-read-all": {
    "method": {
      "const": "GET"
    }
  },
  "coolify-write-all": {
    "method": {
      "enum": ["POST", "PUT", "PATCH", "DELETE"]
    }
  },
  "coolify-read-applications": {
    "method": {
      "const": "GET"
    },
    "path": {
      "type": "string",
      "pattern": "^/api/v[0-9]+/applications(/.*)?$"
    }
  },
  "coolify-write-applications": {
    "method": {
      "enum": ["POST", "PUT", "PATCH", "DELETE"]
    },
    "path": {
      "type": "string",
      "pattern": "^/api/v[0-9]+/applications(/.*)?$"
    }
  },
  "coolify-deployments": {
    "path": {
      "type": "string",
      "pattern": "^/api/v[0-9]+/deploy(ments)?(/.*)?$"
    }
  },
  "coolify-read-databases": {
    "method": {
      "const": "GET"
    },
    "path": {
      "type": "string",
      "pattern": "^/api/v[0-9]+/databases(/.*)?$"
    }
  },
  "coolify-write-databases": {
