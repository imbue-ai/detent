{
  "coolify-api": {
    "properties": {
      "domain": {
        "const": "app.coolify.io"
      }
    },
    "required": [
      "domain"
    ]
  },
  "coolify-read-all": {
    "properties": {
      "method": {
        "const": "GET"
      }
    },
    "required": [
      "method"
    ]
  },
  "coolify-write-all": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      }
    },
    "required": [
      "method"
    ]
  },
  "coolify-read-applications": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/api/v[0-9]+/applications(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
