    },
    "path": {
      "type": "string",
      "pattern": "^/api/v[0-9]+/servers(/.*)?$"
    }
  },
  "coolify-write-servers": {
    "method": {
      "enum": ["POST", "PUT", "PATCH", "DELETE"]
    },
    "path": {
      "type": "string",
      "pattern": "^/api/v[0-9]+/servers(/.*)?$"
    }
  },
  "coolify-read-services": {
    "method": {
      "const": "GET"
    },
    "path": {
      "type": "string",
      "pattern": "^/api/v[0-9]+/services(/.*)?$"
    }
  },
  "coolify-write-services": {
    "method": {
      "enum": ["POST", "PUT", "PATCH", "DELETE"]
    },
