{
  "discord-api": {
    "properties": {
      "domain": {
        "const": "discord.com"
      }
    },
    "required": [
      "domain"
    ]
  },
  "discord-read-all": {
    "properties": {
      "method": {
        "const": "GET"
      }
    },
    "required": [
      "method"
    ]
  },
  "discord-write-all": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      }
    },
    "required": [
      "method"
    ]
  },
  "discord-read-messages": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/api/v[0-9]+/channels/[^/]+/messages(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "discord-write-messages": {
