{
  "slack-api": {
    "domain": {
      "const": "slack.com"
    }
  },
  "slack-read-all": {
    "path": {
      "type": "string",
      "pattern": "^/api/(chat\\.(getPermalink|scheduledMessages\\.list)|conversations\\.(history|info|list|members|replies)|users\\.(conversations|getPresence|identity|info|list|lookupByEmail|profile\\.get)|files\\.(info|list|getUploadURLExternal|remote\\.(info|list))|reactions\\.(get|list)|search\\.(all|files|messages)|pins\\.list|bookmarks\\.list|reminders\\.(info|list))$"
    }
  },
  "slack-write-all": {
    "path": {
      "type": "string",
      "pattern": "^/api/(chat\\.(delete|deleteScheduledMessage|meMessage|postEphemeral|postMessage|scheduleMessage|unfurl|update)|conversations\\.(archive|close|create|invite|join|kick|leave|mark|open|rename|setPurpose|setTopic|unarchive)|users\\.(deletePhoto|setActive|setPhoto|setPresence|profile\\.set)|files\\.(comments\\.delete|completeUploadExternal|delete|remote\\.(add|remove|share|update)|revokePublicURL|sharedPublicURL|upload)|reactions\\.(add|remove)|pins\\.(add|remove)|bookmarks\\.(add|edit|remove)|reminders\\.(add|complete|delete))$"
    }
  },
  "slack-chat-read": {
    "path": {
      "type": "string",
      "pattern": "^/api/chat\\.(getPermalink|scheduledMessages\\.list)$"
    }
  },
  "slack-chat-write": {
    "path": {
      "type": "string",
      "pattern": "^/api/chat\\.(delete|deleteScheduledMessage|meMessage|postEphemeral|postMessage|scheduleMessage|unfurl|update)$"
    }
  },
  "slack-conversations-read": {
    "path": {
      "type": "string",
      "pattern": "^/api/conversations\\.(history|info|list|members|replies)$"
    }
  },
  "slack-conversations-write": {
    "path": {
      "type": "string",
      "pattern": "^/api/conversations\\.(archive|close|create|invite|join|kick|leave|mark|open|rename|setPurpose|setTopic|unarchive)$"
    }
  },
  "slack-users-read": {
    "path": {
      "type": "string",
      "pattern": "^/api/users\\.(conversations|getPresence|identity|info|list|lookupByEmail|profile\\.get)$"
    }
  },
  "slack-users-write": {
    "path": {
      "type": "string",
      "pattern": "^/api/users\\.(deletePhoto|setActive|setPhoto|setPresence|profile\\.set)$"
    }
  },
  "slack-files-read": {
    "path": {
      "type": "string",
      "pattern": "^/api/files\\.(info|list|getUploadURLExternal|remote\\.(info|list))$"
    }
  },
  "slack-files-write": {
    "path": {
      "type": "string",
      "pattern": "^/api/files\\.(comments\\.delete|completeUploadExternal|delete|remote\\.(add|remove|share|update)|revokePublicURL|sharedPublicURL|upload)$"
    }
  },
  "slack-reactions-read": {
    "path": {
      "type": "string",
      "pattern": "^/api/reactions\\.(get|list)$"
    }
  },
  "slack-reactions-write": {
    "path": {
      "type": "string",
      "pattern": "^/api/reactions\\.(add|remove)$"
    }
  },
  "slack-search": {
    "path": {
      "type": "string",
      "pattern": "^/api/search\\.(all|files|messages)$"
    }
  },
  "slack-pins-read": {
    "path": {
      "type": "string",
      "pattern": "^/api/pins\\.list$"
    }
  },
  "slack-pins-write": {
    "path": {
      "type": "string",
      "pattern": "^/api/pins\\.(add|remove)$"
    }
  },
  "slack-bookmarks-read": {
    "path": {
      "type": "string",
      "pattern": "^/api/bookmarks\\.list$"
    }
  },
  "slack-bookmarks-write": {
    "path": {
      "type": "string",
      "pattern": "^/api/bookmarks\\.(add|edit|remove)$"
    }
  },
  "slack-reminders-read": {
    "path": {
      "type": "string",
      "pattern": "^/api/reminders\\.(info|list)$"
    }
  },
  "slack-reminders-write": {
    "path": {
      "type": "string",
      "pattern": "^/api/reminders\\.(add|complete|delete)$"
    }
  }
}
