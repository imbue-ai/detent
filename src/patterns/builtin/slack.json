{
  "slack-api": {
    "properties": {
      "domain": {
        "const": "slack.com"
      }
    },
    "required": [
      "domain"
    ]
  },
  "slack-read-all": {
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/api/(chat\\.(getPermalink|scheduledMessages\\.list)|conversations\\.(history|info|list|listConnectInvites|members|replies|requestSharedInvite\\.list)|users\\.(conversations|getPresence|identity|info|list|lookupByEmail|profile\\.get)|files\\.(info|list|remote\\.(info|list))|reactions\\.(get|list)|search\\.(all|files|messages)|pins\\.list|bookmarks\\.list|reminders\\.(info|list))$"
      }
    },
    "required": [
      "path"
    ]
  },
  "slack-write-all": {
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/api/(chat\\.(appendStream|delete|deleteScheduledMessage|meMessage|postEphemeral|postMessage|scheduleMessage|startStream|stopStream|unfurl|update)|conversations\\.(acceptSharedInvite|approveSharedInvite|archive|canvasCreate|close|create|declineSharedInvite|externalInvitePermissions\\.set|invite|inviteShared|join|kick|leave|mark|open|rename|requestSharedInvite\\.(approve|deny)|setPurpose|setTopic|unarchive)|users\\.(setPresence|profile\\.set)|files\\.(completeUploadExternal|delete|getUploadURLExternal|remote\\.(add|remove|share|update)|revokePublicURL|sharedPublicURL)|reactions\\.(add|remove)|pins\\.(add|remove)|bookmarks\\.(add|edit|remove)|reminders\\.(add|complete|delete))$"
      }
    },
    "required": [
      "path"
    ]
  },
  "slack-chat-read": {
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/api/chat\\.(getPermalink|scheduledMessages\\.list)$"
      }
    },
    "required": [
      "path"
    ]
  },
  "slack-chat-write": {
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/api/chat\\.(appendStream|delete|deleteScheduledMessage|meMessage|postEphemeral|postMessage|scheduleMessage|startStream|stopStream|unfurl|update)$"
      }
    },
    "required": [
      "path"
    ]
  },
  "slack-conversations-read": {
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/api/conversations\\.(history|info|list|listConnectInvites|members|replies|requestSharedInvite\\.list)$"
      }
    },
    "required": [
      "path"
    ]
  },
  "slack-conversations-write": {
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/api/conversations\\.(acceptSharedInvite|approveSharedInvite|archive|canvasCreate|close|create|declineSharedInvite|externalInvitePermissions\\.set|invite|inviteShared|join|kick|leave|mark|open|rename|requestSharedInvite\\.(approve|deny)|setPurpose|setTopic|unarchive)$"
      }
    },
    "required": [
      "path"
    ]
  },
  "slack-users-read": {
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/api/users\\.(conversations|getPresence|identity|info|list|lookupByEmail|profile\\.get)$"
      }
    },
    "required": [
      "path"
    ]
  },
  "slack-users-write": {
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/api/users\\.(setPresence|profile\\.set)$"
      }
    },
    "required": [
      "path"
    ]
  },
  "slack-files-read": {
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/api/files\\.(info|list|remote\\.(info|list))$"
      }
    },
    "required": [
      "path"
    ]
  },
  "slack-files-write": {
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/api/files\\.(completeUploadExternal|delete|getUploadURLExternal|remote\\.(add|remove|share|update)|revokePublicURL|sharedPublicURL)$"
      }
    },
    "required": [
      "path"
    ]
  },
  "slack-reactions-read": {
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/api/reactions\\.(get|list)$"
      }
    },
    "required": [
      "path"
    ]
  },
  "slack-reactions-write": {
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/api/reactions\\.(add|remove)$"
      }
    },
    "required": [
      "path"
    ]
  },
  "slack-search": {
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/api/search\\.(all|files|messages)$"
      }
    },
    "required": [
      "path"
    ]
  },
  "slack-pins-read": {
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/api/pins\\.list$"
      }
    },
    "required": [
      "path"
    ]
  },
  "slack-pins-write": {
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/api/pins\\.(add|remove)$"
      }
    },
    "required": [
      "path"
    ]
  },
  "slack-bookmarks-read": {
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/api/bookmarks\\.list$"
      }
    },
    "required": [
      "path"
    ]
  },
  "slack-bookmarks-write": {
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/api/bookmarks\\.(add|edit|remove)$"
      }
    },
    "required": [
      "path"
    ]
  },
  "slack-reminders-read": {
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/api/reminders\\.(info|list)$"
      }
    },
    "required": [
      "path"
    ]
  },
  "slack-reminders-write": {
    "properties": {
      "path": {
        "type": "string",
        "pattern": "^/api/reminders\\.(add|complete|delete)$"
      }
    },
    "required": [
      "path"
    ]
  }
}
