{
  "notion-api": {
    "properties": {
      "domain": {
        "const": "api.notion.com"
      }
    },
    "required": [
      "domain"
    ]
  },
  "notion-read-all": {
    "anyOf": [
      {
        "properties": {
          "method": {
            "const": "GET"
          }
        },
        "required": [
          "method"
        ]
      },
      {
        "properties": {
          "method": {
            "const": "POST"
          },
          "path": {
            "type": "string",
            "pattern": "^/v1/search$"
          }
        },
        "required": [
          "method",
          "path"
        ]
      }
    ]
  },
  "notion-write-all": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PUT",
          "PATCH",
          "DELETE"
        ]
      }
    },
    "required": [
      "method"
    ]
  },
  "notion-read-pages": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v1/pages(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "notion-write-pages": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PATCH"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/v1/pages(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "notion-read-blocks": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v1/blocks(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "notion-write-blocks": {
    "properties": {
      "method": {
        "enum": [
          "PATCH",
          "DELETE"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/v1/blocks(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "notion-read-databases": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v1/databases(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "notion-write-databases": {
    "properties": {
      "method": {
        "enum": [
          "POST",
          "PATCH"
        ]
      },
      "path": {
        "type": "string",
        "pattern": "^/v1/databases(/[^/]+)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "notion-query-databases": {
    "properties": {
      "method": {
        "const": "POST"
      },
      "path": {
        "type": "string",
        "pattern": "^/v1/databases/[^/]+/query$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "notion-read-users": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v1/users(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "notion-read-comments": {
    "properties": {
      "method": {
        "const": "GET"
      },
      "path": {
        "type": "string",
        "pattern": "^/v1/comments(/.*)?$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "notion-write-comments": {
    "properties": {
      "method": {
        "const": "POST"
      },
      "path": {
        "type": "string",
        "pattern": "^/v1/comments$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  },
  "notion-search": {
    "properties": {
      "method": {
        "const": "POST"
      },
      "path": {
        "type": "string",
        "pattern": "^/v1/search$"
      }
    },
    "required": [
      "method",
      "path"
    ]
  }
}
