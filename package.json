{
  "name": "@imbue-ai/detent",
  "version": "1.1.1",
  "description": "Fine-grained HTTP permissions for AI agents.",
  "author": "Imbue <hynek@imbue.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imbue-ai/detent.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/imbue-ai/detent#readme",
  "bugs": {
    "url": "https://github.com/imbue-ai/detent/issues"
  },
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "bin": {
    "detent": "./dist/src/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "tsc && cp -r src/schemas/builtin dist/src/schemas/builtin && chmod +x dist/src/cli.js",
    "dev": "tsc --watch",
    "docs": "tsx scripts/generateBuiltinSchemaDocs.ts",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/src/cli.js"
  },
  "keywords": [
    "cli",
    "curl",
    "api",
    "permission",
    "check",
    "agents",
    "imbue"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^20.0.0",
    "eslint": "^9.39.2",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.53.1",
    "vitest": "^4.0.18"
  }
}
